# Copy this file to secret.yaml, fill in base64-encoded values, then apply:
#   kubectl apply -f apps/neonatal-care/secret.yaml -n neonatal-care
#
# To base64 encode a value:
#   echo -n 'your-value' | base64
#
# secret.yaml is gitignored. For production use Sealed Secrets or External Secrets Operator.
apiVersion: v1
kind: Secret
metadata:
  name: neonatal-care-secrets
  namespace: neonatal-care
type: Opaque
data:
  # ClickHouse
  DB_PASSWORD: Y2xpY2tob3VzZQ==           # base64('clickhouse') — CHANGE THIS
  CLICKHOUSE_PASSWORD: Y2xpY2tob3VzZQ==   # CHANGE THIS

  # MinIO
  MINIO_ROOT_USER: bWluaW9hZG1pbg==       # base64('minioadmin') — CHANGE THIS
  MINIO_ROOT_PASSWORD: bWluaW9hZG1pbg==   # CHANGE THIS
  MINIO_ACCESS_KEY: bWluaW9hZG1pbg==      # CHANGE THIS
  MINIO_SECRET_KEY: bWluaW9hZG1pbg==      # CHANGE THIS

  # Azure OpenAI
  AZURE_OPENAI_KEY: CHANGE_ME_BASE64
  AZURE_OPENAI_ENDPOINT: CHANGE_ME_BASE64
  AZURE_OPENAI_DEPLOYMENT: CHANGE_ME_BASE64

  # AssemblyAI (optional, for cloud transcription)
  ASSEMBLYAI_API_KEY: CHANGE_ME_BASE64

  # n8n webhook
  N8N_WEBHOOK_ID: CHANGE_ME_BASE64
