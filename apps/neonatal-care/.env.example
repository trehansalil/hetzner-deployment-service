# Environment variable reference for neonatal-care on Hetzner K8s
# Non-secret values go in configmap.yaml
# Secret values go in secret.yaml (base64 encoded)

# ── Non-secret (configmap.yaml) ───────────────────────────────────
TZ=Asia/Kolkata
DB_HOST=neonatal-care-clickhouse
DB_NAME=baby_tracker
DB_USER=clickhouse
DB_PORT=8123
CLICKHOUSE_DB=baby_tracker
CLICKHOUSE_USER=clickhouse
MINIO_ENDPOINT=neonatal-care-minio:9000
MINIO_EXTERNAL_ENDPOINT=neonate-logger.saliltrehan.com/minio
REDIS_URL=redis://neonatal-care-redis:6379/0
N8N_HOST=neonatal-care-n8n:5678
WEBHOOK_URL=https://neonate-logger.saliltrehan.com/automation/
ENABLE_HTTPS=false
ENABLE_BACKGROUND_NOTIFICATIONS=false
EXTERNAL_TRANSCRIPTION_SERVICE_BOOL=0
DIAPER_ALERT_HOURS=4
NOTIFICATION_CHECK_INTERVAL_MINUTES=60
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Secret (secret.yaml — gitignored) ─────────────────────────────
DB_PASSWORD=CHANGE_ME
CLICKHOUSE_PASSWORD=CHANGE_ME
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
AZURE_OPENAI_KEY=CHANGE_ME
AZURE_OPENAI_ENDPOINT=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=CHANGE_ME
ASSEMBLYAI_API_KEY=CHANGE_ME
N8N_WEBHOOK_ID=CHANGE_ME
