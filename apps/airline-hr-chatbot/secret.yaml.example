# secret.yaml.example — copy to secret.yaml, fill in base64-encoded values, then:
#   kubectl apply -f apps/airline-hr-chatbot/secret.yaml -n hr-chatbot
#
# To base64-encode a value:  echo -n 'myvalue' | base64
#
# secret.yaml is gitignored — never commit real secrets.
---
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: hr-chatbot
type: Opaque
data:
  # OpenAI API key (required)
  OPENAI_API_KEY: <base64-encoded-openai-api-key>

  # PostgreSQL credentials
  POSTGRES_USER: <base64-encoded-postgres-user>         # e.g. echo -n 'hrchatbot' | base64
  POSTGRES_PASSWORD: <base64-encoded-postgres-password>
  POSTGRES_DB: <base64-encoded-postgres-db>             # e.g. echo -n 'hrchatbot' | base64

  # Full connection URL (must match POSTGRES_USER/PASSWORD/DB above)
  # e.g. echo -n 'postgresql://hrchatbot:password@postgres:5432/hrchatbot' | base64
  DATABASE_URL: <base64-encoded-database-url>

  # Chainlit auth secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
  CHAINLIT_AUTH_SECRET: <base64-encoded-chainlit-auth-secret>
---
apiVersion: v1
kind: Secret
metadata:
  name: monitoring-secrets
  namespace: hr-chatbot
type: Opaque
data:
  # Grafana admin credentials
  GF_SECURITY_ADMIN_USER: YWRtaW4=      # base64: admin
  GF_SECURITY_ADMIN_PASSWORD: YWRtaW4=  # base64: admin (change in production!)
